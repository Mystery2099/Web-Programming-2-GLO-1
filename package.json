{
	"name": "march-celebration",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run src/server/index.js",
		"build": "echo 'No build step needed - pure server implementation'",
		"format": "prettier --write \"**/*.{js,css,html,json,ts,tsx}\"",
		"typecheck": "tsc --noEmit",
		"lint": "eslint \"src/**/*.{ts,tsx}\"",
		"lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
		"check": "bun run typecheck && bun run lint",
		"docs": "typedoc",
		"docs:serve": "typedoc --serve"
	},
	"devDependencies": {
		"@kitajs/ts-html-plugin": "^4.1.4",
		"@types/node": "^25.3.3",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"typescript": "^5.9.3",
		"vite": "^5.4.21"
	},
	"dependencies": {
		"@elysiajs/html": "^1.4.0",
		"@elysiajs/static": "^1.4.7",
		"@gtramontina.com/elysia-htmx": "^2.0.0",
		"bun-types": "^1.3.10",
		"elysia": "^1.4.27",
		"glightbox": "^3.3.1",
		"htmx.org": "^2.0.8",
		"localforage": "^1.10.0",
		"lucide": "^0.575.0",
		"modern-normalize": "^3.0.1",
		"zod": "^4.3.6"
	}
}
